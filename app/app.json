{
  "expo": {
    "name": "Voice AI Agent",
    "slug": "voice-ai-agent",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.yourname.voiceaiagent",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECORD_AUDIO",
        "INTERNET"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "data": [
            {
              "mimeType": "audio/*"
            }
          ],
          "category": [
            "android.intent.category.DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-document-picker"
    ],
    "extra": {
      "eas": {
        "projectId": "775a1a12-816c-4c37-9922-aaa416d4c567"
      }
    }
  }
}
